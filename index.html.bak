/* ================= STATISTIK FILTER TOOLBAR ================= */

function toggleStFilterDropdown() {
  toggleLtDropdown('stFilterDropdown', 'stFilterBtn');
}

function onStZeitraumChange() {
  const val = document.getElementById('statistikFilterZeitraum').value;
  const range = document.getElementById('statistikCustomDateRange');
  if (range) range.style.display = val === 'custom' ? 'block' : 'none';
  updateStFilterUI();
}

function updateStFilterUI() {
  const fields = [
    { id: 'statistikFilterDisziplin', label: 'Disziplin', type: 'select' },
    { id: 'statistikFilterZeitraum',  label: 'Zeitraum',  type: 'select-jahr' },
    { id: 'statistikFilterVon',       label: 'Von',       type: 'date' },
    { id: 'statistikFilterBis',       label: 'Bis',       type: 'date' },
    { id: 'statistikFilterOrt',       label: 'Ort',       type: 'text' },
    { id: 'statistikFilterWK',        label: 'Wettkampf', type: 'text' },
    { id: 'statistikFilterAK',        label: 'Altersklasse', type: 'text' },
    { id: 'statistikFilterTyp',       label: 'Saison',    type: 'select' },
    { id: 'statistikFilterMS',        label: 'Meisterschaft', type: 'select' },
  ];

  const chips = [];
  fields.forEach(({ id, label, type }) => {
    const el = document.getElementById(id);
    if (!el || !el.value) return;
    // Skip Von/Bis if Zeitraum is not 'custom'
    if ((id === 'statistikFilterVon' || id === 'statistikFilterBis')) {
      const zt = document.getElementById('statistikFilterZeitraum');
      if (!zt || zt.value !== 'custom') return;
    }
    const displayVal = type === 'select' || type === 'select-jahr'
      ? (el.options[el.selectedIndex]?.text || el.value)
      : el.value;
    chips.push({ label, value: displayVal, id });
  });

  // Badge
  const badge = document.getElementById('stFilterBadge');
  if (badge) {
    badge.textContent = chips.length;
    badge.style.display = chips.length > 0 ? 'inline-flex' : 'none';
  }
  const btn = document.getElementById('stFilterBtn');
  if (btn) btn.classList.toggle('lt-active', chips.length > 0);

  // Chips container
  const container = document.getElementById('stChipsContainer');
  if (!container) return;
  container.innerHTML = '';
  container.style.display = chips.length > 0 ? 'flex' : 'none';
  chips.forEach(({ label, value, id }) => {
    const chip = document.createElement('span');
    chip.className = 'lt-chip';
    const safeId = id.replace(/'/g, "\'");
    chip.innerHTML =
      `<span class="lt-chip-key">${label}:</span> ${value}` +
      `<button class="lt-chip-remove" title="Filter entfernen" onclick="removeStChip('${safeId}')">×</button>`;
    container.appendChild(chip);
  });
}

function removeStChip(fieldId) {
  const el = document.getElementById(fieldId);
  if (!el) return;
  el.value = '';
  if (fieldId === 'statistikFilterZeitraum') {
    const range = document.getElementById('statistikCustomDateRange');
    if (range) range.style.display = 'none';
    document.getElementById('statistikFilterVon').value = '';
    document.getElementById('statistikFilterBis').value = '';
  }
  updateStFilterUI();
}




function bestleistungenFilterZuruecksetzen() {
    document.getElementById('bestleistungenFilterOrt').value = '';
    document.getElementById('bestleistungenFilterDisziplin').value = '';
    document.getElementById('bestleistungenFilterWK').value = '';
    document.getElementById('bestleistungenFilterAK').value = '';
    document.getElementById('bestleistungenFilterTyp').value = '';
    document.getElementById('bestleistungenFilterMS').value = '';
    document.getElementById('bestleistungenFilterZeitraum').value = '';
    document.getElementById('bestleistungenFilterVon').value = '';
