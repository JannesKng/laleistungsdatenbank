      <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Ort</label>
      <input type="text" id="cpLocation" placeholder="z.B. Berlin" style="width:100%; padding:9px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box;">
