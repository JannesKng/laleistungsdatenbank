    const aktuellerWert = dropdown.value;
    dropdown.innerHTML = '<option value="">– alle –</option>' + 
      disziplinenListe.map(d => `<option value="${d}">${d}</option>`).join('');
    // Versuche, den alten Wert wiederherzustellen (falls noch in der neuen Liste)
    if (aktuellerWert && disziplinenListe.includes(aktuellerWert)) {
      dropdown.value = aktuellerWert;
    }
  });
  
  // Aktualisiere Statistik-Filter Disziplin-Dropdown
  const statistikFilterDisziplin = document.getElementById('statistikFilterDisziplin');
  if (statistikFilterDisziplin) {
    const aktuellerWert = statistikFilterDisziplin.value;
    statistikFilterDisziplin.innerHTML = '<option value="">– Alle –</option>' + 
      disziplinenListe.map(d => `<option value="${d}">${d}</option>`).join('');
    if (aktuellerWert && disziplinenListe.includes(aktuellerWert)) {
      statistikFilterDisziplin.value = aktuellerWert;
    }
  }
  
  // Aktualisiere Bestleistungen-Filter Disziplin-Dropdown
  const bestleistungenFilterDisziplin = document.getElementById('bestleistungenFilterDisziplin');
  if (bestleistungenFilterDisziplin) {
    const aktuellerWert = bestleistungenFilterDisziplin.value;
    bestleistungenFilterDisziplin.innerHTML = '<option value="">– Alle –</option>' + 
      disziplinenListe.map(d => `<option value="${d}">${d}</option>`).join('');
    if (aktuellerWert && disziplinenListe.includes(aktuellerWert)) {
      bestleistungenFilterDisziplin.value = aktuellerWert;
    }
  }
  
  // Aktualisiere Analyse-Disziplin Dropdown
  const analyseDisziplinSelect = document.getElementById('analyseDisziplin');
  if (analyseDisziplinSelect) {
    const aktuellerWert = analyseDisziplinSelect.value;
    analyseDisziplinSelect.innerHTML = '<option value="">– Disziplin wählen –</option>' + 
      disziplinenListe.map(d => `<option value="${d}">${d}</option>`).join('');
    if (aktuellerWert && disziplinenListe.includes(aktuellerWert)) {
      analyseDisziplinSelect.value = aktuellerWert;
    }
  }
  
  // Aktualisiere Prognose-Disziplin Dropdown
  const prognoseDisziplinSelect = document.getElementById('prognoseDisziplin');
  if (prognoseDisziplinSelect) {
    const aktuellerWert = prognoseDisziplinSelect.value;
    prognoseDisziplinSelect.innerHTML = '<option value="">– Disziplin wählen –</option>' + 
      disziplinenListe.map(d => `<option value="${d}">${d}</option>`).join('');
    if (aktuellerWert && disziplinenListe.includes(aktuellerWert)) {
      prognoseDisziplinSelect.value = aktuellerWert;
    }
  }
  
  // Aktualisiere Altersklassen-Dropdown
  const akDropdowns = document.querySelectorAll('[data-filter-dropdown="ak"]');
  akDropdowns.forEach(dropdown => {
    const aktuellerWert = dropdown.value;
    dropdown.innerHTML = '<option value="">– alle –</option>' + 
      alleAK.map(a => `<option value="${a}">${a}</option>`).join('');
    if (aktuellerWert && alleAK.includes(aktuellerWert)) {
