  }
  
  // Aktualisiere alle Disziplin-Dropdowns im Leistungen-Tab
  const disziplinDropdowns = document.querySelectorAll('.disziplin-dropdown');
  console.log('Gefundene Disziplin-Dropdowns:', disziplinDropdowns.length);
