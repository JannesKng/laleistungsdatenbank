    /* Tablet Portrait & Mobile Landscape (481px - 768px) */
    @media (min-width: 481px) and (max-width: 768px) {
      .detail-popup-content {
        width: 98%;
        height: 95vh;
        min-width: 0;
        padding: 0;
      }
      
