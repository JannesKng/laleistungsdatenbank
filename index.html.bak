};

/* ================= GLOBALE DATEN ================= */
let sortSpalte = null;
let sortAsc = true;
let sortSpalteAthleten = null;
let sortAscAthleten = true;
let disziplinenListe = [];
let alleAK = [];
let alleRunden = [];
let alleMS = [];
let aktuelleLeistungsdaten = null;
let alleLeistungenFuerPBs = []; // Alle Leistungen für PB-Berechnung (ungefiltert)
let verfuegbareJahre = [];
