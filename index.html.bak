})();

function switchTabMitDisziplinFilter(disziplin) {
  switchTab('leistungen');
  // Warte kurz bis Tab sichtbar und Filter-Container gerendert ist
  setTimeout(() => {
    const container = document.getElementById('disziplinFilterContainer');
    if (!container) return;
    // Ersten Dropdown auf die gewählte Disziplin setzen
    const firstDd = container.querySelector('.disziplin-dropdown');
    if (firstDd) {
      firstDd.value = disziplin;
      // X-Button sichtbar machen
      const xBtn = firstDd.closest('.disziplin-filter-row')?.querySelector('.disziplin-entfernen-btn');
      if (xBtn) xBtn.style.display = 'inline-flex';
    }
    // Alle anderen Dropdowns leeren
    const allDds = container.querySelectorAll('.disziplin-dropdown');
    allDds.forEach((dd, i) => { if (i > 0) dd.value = ''; });
    // Tabelle neu laden
    ladeLeistungen();
  }, 100);
}


function normalizeOrtName(ort) {
  // Handle null/undefined values
  if (!ort) return '';
  
  // Entferne führende/nachfolgende Leerzeichen
  let normalized = ort.trim();
  
  // Ersetze Umlaute
  normalized = normalized
    .replace(/ä/g, 'ae')
    .replace(/ö/g, 'oe')
    .replace(/ü/g, 'ue')
    .replace(/Ä/g, 'Ae')
    .replace(/Ö/g, 'Oe')
    .replace(/Ü/g, 'Ue')
    .replace(/ß/g, 'ss');
  
  // Erster Buchstabe groß, Rest klein
  normalized = normalized.charAt(0).toUpperCase() + normalized.slice(1).toLowerCase();
  
  return normalized;
}

