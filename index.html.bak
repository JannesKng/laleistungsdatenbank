  "vl": "Vorlauf",
  "hf": "Halbfinale",
  "zl": "Zeitlauf",
  "af": "A-Finale",
  "bf": "B-Finale",
  "f":  "Finale"
};

const TYP_ANZEIGE = {
  "h": "Halle",
  "f": "Freiluft"
};

/* ================= WETTKAMPF-HILFSFUNKTIONEN ================= */
// Definition: Ein Wettkampf = gleiche wk_bz im selben Jahr
function zähleWettkämpfe(leistungen) {
  if (!leistungen || leistungen.length === 0) return 0;
  
  // Sammle alle Wettkämpfe mit wk_bz und Datum
  const wettkampfListe = [];
  leistungen.forEach(l => {
    if (l.wk_bz && l.datum) {
      wettkampfListe.push({
        wk_bz: l.wk_bz,
        datum: new Date(l.datum)
      });
    }
  });
  
  if (wettkampfListe.length === 0) return 0;
  
  // Sortiere nach Wettkampfbezeichnung und dann nach Datum
  wettkampfListe.sort((a, b) => {
    if (a.wk_bz !== b.wk_bz) {
      return a.wk_bz.localeCompare(b.wk_bz);
    }
    return a.datum - b.datum;
  });
  
  // Gruppiere Wettkämpfe: gleiche wk_bz innerhalb von 14 Tagen = ein Wettkampf
  const wettkämpfeSet = new Set();
  let letzterWK = null;
  let letztesDatum = null;
  let wettkampfCounter = 0;
  
  wettkampfListe.forEach(wk => {
    if (letzterWK === null || wk.wk_bz !== letzterWK) {
      // Neuer Wettkampf (andere Bezeichnung)
      wettkämpfeSet.add(`${wk.wk_bz}_${wettkampfCounter++}`);
      letzterWK = wk.wk_bz;
      letztesDatum = wk.datum;
    } else {
      // Gleiche Wettkampfbezeichnung - prüfe Zeitdifferenz
      const diffTage = (wk.datum - letztesDatum) / (1000 * 60 * 60 * 24);
      
      if (diffTage > 14) {
        // Mehr als 14 Tage Unterschied = neuer Wettkampf
        wettkämpfeSet.add(`${wk.wk_bz}_${wettkampfCounter++}`);
        letztesDatum = wk.datum;
      }
      // Sonst: Gehört zum gleichen Wettkampf, nichts hinzufügen
    }
  });
  
  return wettkämpfeSet.size;
}

// Gruppiere Leistungen nach Wettkämpfen
function gruppiereNachWettkämpfen(leistungen) {
  if (!leistungen || leistungen.length === 0) return [];
  
  // Filtere nur Einträge mit wk_bz und Datum
  const relevanteLeistungen = leistungen.filter(l => l.wk_bz && l.datum);
  
  if (relevanteLeistungen.length === 0) return [];
  
  // Sortiere nach Wettkampfbezeichnung und dann nach Datum
  relevanteLeistungen.sort((a, b) => {
    if (a.wk_bz !== b.wk_bz) {
      return a.wk_bz.localeCompare(b.wk_bz);
    }
    return new Date(a.datum) - new Date(b.datum);
  });
  
  // Gruppiere Wettkämpfe: gleiche wk_bz innerhalb von 14 Tagen = ein Wettkampf
  const wettkämpfe = [];
  let aktuellerWettkampf = null;
  
  relevanteLeistungen.forEach(l => {
    const datum = new Date(l.datum);
    
    if (aktuellerWettkampf === null) {
      // Erster Wettkampf
      aktuellerWettkampf = {
        wk_bz: l.wk_bz,
        jahr: datum.getFullYear(),
        datum: l.datum,
        ort: l.ort,
        leistungen: [l]
      };
    } else if (l.wk_bz !== aktuellerWettkampf.wk_bz) {
      // Neue Wettkampfbezeichnung - speichere aktuellen und starte neuen
      wettkämpfe.push(aktuellerWettkampf);
      aktuellerWettkampf = {
        wk_bz: l.wk_bz,
        jahr: datum.getFullYear(),
        datum: l.datum,
        ort: l.ort,
        leistungen: [l]
      };
    } else {
      // Gleiche Wettkampfbezeichnung - prüfe Zeitdifferenz
      const letztesDatum = new Date(aktuellerWettkampf.datum);
      const diffTage = (datum - letztesDatum) / (1000 * 60 * 60 * 24);
      
      if (diffTage > 14) {
        // Mehr als 14 Tage Unterschied = neuer Wettkampf
        wettkämpfe.push(aktuellerWettkampf);
        aktuellerWettkampf = {
          wk_bz: l.wk_bz,
          jahr: datum.getFullYear(),
          datum: l.datum,
          ort: l.ort,
          leistungen: [l]
        };
      } else {
        // Innerhalb von 14 Tagen = gehört zum gleichen Wettkampf
        aktuellerWettkampf.leistungen.push(l);
        // Aktualisiere Datum auf das späteste
        if (datum > letztesDatum) {
          aktuellerWettkampf.datum = l.datum;
        }
      }
    }
  });
  
  // Füge den letzten Wettkampf hinzu
  if (aktuellerWettkampf !== null) {
    wettkämpfe.push(aktuellerWettkampf);
  }
  
  return wettkämpfe;
}

/* ================= SPALTEN ================= */

/* ── Compact Toolbar: Dropdown-Toggle ── */
function toggleLtDropdown(dropId, btnId) {
  const drop = document.getElementById(dropId);
  const btn  = document.getElementById(btnId);
  if (!drop) return;
  const isOpen = drop.classList.contains('lt-open');
  // Close all dropdowns first
  document.querySelectorAll('.lt-dropdown').forEach(d => d.classList.remove('lt-open'));
  document.querySelectorAll('.lt-btn').forEach(b => b.classList.remove('lt-active'));
  if (!isOpen) {
    drop.classList.add('lt-open');
    if (btn) btn.classList.add('lt-active');
  }
}

/* Close toolbar dropdowns when clicking outside */
document.addEventListener('click', function(e) {
  if (!e.target.closest('.lt-btn') && !e.target.closest('.lt-dropdown')) {
    document.querySelectorAll('.lt-dropdown').forEach(d => d.classList.remove('lt-open'));
    document.querySelectorAll('.lt-btn').forEach(b => b.classList.remove('lt-active'));
  }
});

/* ── Filter-Chip helpers ──────────────────────────────────────────────── */

/**
 * Sammelt alle aktiven Filter als Chip-Objekte:
 *   { label, value, key, chipKey }
 *  key      = interner Schlüssel für gezielte Löschung
 *  chipKey  = eindeutiger String für data-Attribut im Chip
 */
function collectActiveFilterChips() {
  const chips = [];
  const fg = document.querySelectorAll('#filterContainer .ls-fg');

  fg.forEach(group => {
    const labelEl  = group.querySelector('.ls-fg-label');
    const rawLabel = labelEl ? labelEl.textContent.trim() : '';

    /* ── Disziplin-Multiselect ─────────────────────────────────── */
    const diszContainer = group.querySelector('#disziplinFilterContainer');
    if (diszContainer) {
      // Ausgewählte Dropdowns
      diszContainer.querySelectorAll('.disziplin-dropdown').forEach(dd => {
        if (dd.value) {
          chips.push({
            label:   rawLabel,
            value:   dd.value,
            chipKey: 'disziplin-dd|' + dd.value
          });
        }
      });
      // Freitext-Suche
      const suche = diszContainer.querySelector('.disziplin-suche');
      if (suche && suche.value.trim()) {
        chips.push({
          label:   rawLabel,
          value:   '"' + suche.value.trim() + '"',
          chipKey: 'disziplin-suche|' + suche.value.trim()
        });
      }
      return; // Gruppe fertig
    }

    /* ── Zahlen-Filter (leistung, platzierung, score) ─────────── */
    const numInp = group.querySelector('input[type="number"][data-filter]');
    if (numInp) {
      if (numInp.value !== '') {
        const opSel = group.querySelector('select[data-op]');
        const opTxt = opSel && opSel.value === 'lte' ? '≤' : '≥';
        chips.push({
          label:   rawLabel,
          value:   opTxt + '\u202f' + numInp.value,
          chipKey: 'number|' + numInp.dataset.filter + '|' + numInp.value
        });
      }
      return;
    }

    /* ── Text-Filter ───────────────────────────────────────────── */
    const textInp = group.querySelector('input[type="text"][data-filter]');
    if (textInp && textInp.value.trim()) {
      chips.push({
        label:   rawLabel,
        value:   textInp.value.trim(),
        chipKey: 'text|' + textInp.dataset.filter + '|' + textInp.value.trim()
      });
      return;
    }

    /* ── Datum-Filter ──────────────────────────────────────────── */
    const dateFrom = group.querySelector('[data-filter-from]');
    const dateTo   = group.querySelector('[data-filter-to]');
    const dateJahr = group.querySelector('[data-filter-jahr]');
    if (dateJahr && dateJahr.value) {
      chips.push({
        label:   rawLabel,
        value:   dateJahr.value,
        chipKey: 'jahr|' + dateJahr.dataset.filterJahr + '|' + dateJahr.value
      });
      return;
    }
    if (dateFrom && dateFrom.value) {
      chips.push({
        label:   rawLabel,
        value:   'ab ' + dateFrom.value,
        chipKey: 'date-from|' + dateFrom.dataset.filterFrom + '|' + dateFrom.value
      });
    }
    if (dateTo && dateTo.value) {
      chips.push({
        label:   rawLabel,
        value:   'bis ' + dateTo.value,
        chipKey: 'date-to|' + dateTo.dataset.filterTo + '|' + dateTo.value
      });
    }
    if (dateFrom && dateFrom.value) return;
    if (dateTo   && dateTo.value)   return;

    /* ── Generische Dropdowns (AK, Runde, Saison, fixed-select) ─ */
    const dd = group.querySelector(
      'select[data-filter-dropdown]:not([data-filter-dropdown="disziplin"]),' +
      'select[data-filter-jahr]'
    );
    if (dd && dd.value) {
      chips.push({
        label:   rawLabel,
        value:   dd.options[dd.selectedIndex]?.text || dd.value,
        chipKey: 'select|' + (dd.dataset.filterDropdown || dd.dataset.filterJahr) + '|' + dd.value
      });
      return;
    }

    /* ── Checkboxen ────────────────────────────────────────────── */
    const checked = Array.from(group.querySelectorAll('input[type="checkbox"]')).filter(c => c.checked);
    if (checked.length) {
      chips.push({
        label:   rawLabel,
        value:   checked.map(c => c.value || c.name).join(', '),
        chipKey: 'checkbox|' + rawLabel
      });
    }
  });

  return chips;
}

/* Rendert die Chips über der Tabelle */
function updateLtFilterUI() {
  const badge         = document.getElementById('ltFilterBadge');
  const chipsContainer = document.getElementById('ltChipsContainer');
  if (!chipsContainer) return;

  const chips = collectActiveFilterChips();

  if (badge) {
    badge.textContent  = chips.length;
    badge.style.display = chips.length > 0 ? 'inline-flex' : 'none';
  }

  chipsContainer.innerHTML = '';
  chipsContainer.style.display = chips.length > 0 ? 'flex' : 'none';
  chips.forEach(({ label, value, chipKey }) => {
    const chip = document.createElement('span');
    chip.className = 'lt-chip';
    chip.dataset.chipKey = chipKey;
    const safeKey = chipKey.replace(/'/g, "\\'");
    chip.innerHTML =
      `<span class="lt-chip-key">${label}:</span>\u202f${value}` +
      `<button class="lt-chip-remove" title="Filter entfernen" ` +
      `onclick="removeFilterChip(this,'${safeKey}')">×</button>`;
    chipsContainer.appendChild(chip);
  });
}

/* Entfernt einen einzelnen aktiven Filter anhand seines chipKey */
function removeFilterChip(btn, chipKey) {
  const [type, field, val] = chipKey.split('|');

  if (type === 'disziplin-dd') {
    // Finde das exakte Dropdown mit diesem Wert und setze es zurück
    const container = document.getElementById('disziplinFilterContainer');
    if (container) {
      container.querySelectorAll('.disziplin-dropdown').forEach(dd => {
        if (dd.value === field) {   // field = der Wert des Dropdowns (2. Teil nach split)
          dd.value = '';
          const xBtn = dd.closest('.disziplin-filter-row')?.querySelector('.disziplin-entfernen-btn');
          if (xBtn) xBtn.style.display = 'none';
        }
      });
      // Such-Feld wieder einblenden wenn keine Disziplin mehr aktiv
      const anySelected = Array.from(container.querySelectorAll('.disziplin-dropdown')).some(d => d.value);
      const suchWrapper = container.querySelector('.disziplin-suche-wrapper');
      if (suchWrapper) suchWrapper.style.display = anySelected ? 'none' : '';
    }
  } else if (type === 'disziplin-suche') {
    const suche = document.querySelector('#disziplinFilterContainer .disziplin-suche');
    if (suche) suche.value = '';
  } else if (type === 'number') {
    const inp = document.querySelector(`input[type="number"][data-filter="${field}"]`);
    if (inp) inp.value = '';
  } else if (type === 'text') {
    const inp = document.querySelector(`input[type="text"][data-filter="${field}"]`);
    if (inp) inp.value = '';
  } else if (type === 'jahr') {
    const sel = document.querySelector(`select[data-filter-jahr="${field}"]`);
    if (sel) sel.value = '';
  } else if (type === 'date-from') {
    const inp = document.querySelector(`[data-filter-from="${field}"]`);
    if (inp) inp.value = '';
  } else if (type === 'date-to') {
    const inp = document.querySelector(`[data-filter-to="${field}"]`);
    if (inp) inp.value = '';
  } else if (type === 'select') {
    const sel = document.querySelector(
      `select[data-filter-dropdown="${field}"], select[data-filter-jahr="${field}"]`
    );
    if (sel) sel.value = '';
  } else if (type === 'checkbox') {
    // field ist hier der rawLabel; alle Checkboxen in der Gruppe deaktivieren
    document.querySelectorAll('#filterContainer .ls-fg').forEach(group => {
      const lbl = group.querySelector('.ls-fg-label')?.textContent?.trim() || '';
      if (lbl === field) {
        group.querySelectorAll('input[type="checkbox"]').forEach(c => { c.checked = false; });
      }
    });
  }

  ladeLeistungen();
  updateLtFilterUI();
}

