      <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Beschreibung</label>
      <textarea id="cpDescription" placeholder="Optionale Notizen" rows="2" style="width:100%; padding:9px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box; resize:vertical; font-family:inherit;"></textarea>
    </div>
    <p style="font-size:0.8em; color:#666; margin:6px 0 12px;">* Pflichtfeld</p>
    <div style="display:flex; gap:10px; justify-content:space-between; align-items:center;">
      <button id="cpDeleteBtn" onclick="deleteCompetitionFromForm()" style="display:none; padding:10px 16px; border:none; border-radius:8px; cursor:pointer; font-weight:600; background:#dc2626; color:white;">Löschen</button>
      <div style="display:flex; gap:10px; margin-left:auto;">
        <button onclick="closeCompetitionForm()" style="padding:10px 20px; border:none; border-radius:8px; cursor:pointer; font-weight:600; background:#6c757d; color:white;">Abbrechen</button>
