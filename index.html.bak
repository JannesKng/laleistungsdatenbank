}



/* ================= TABLE SEARCH FUNCTIONALITY ================= */
let originalColumnSelection = null; // Snapshot vor der Suche
let searchActivatedColumns   = new Set(); // cb.value die durch Suche aktiviert wurden
let manuallyChangedColumns   = new Set(); // cb.value die manuell während der Suche geändert wurden
let sucheTabelleBereit       = false;

function filterTable() {
  const searchInput = document.getElementById('tableSearchInput');
  const clearBtn    = document.getElementById('clearSearchBtn');
  const searchTerm  = searchInput.value.toLowerCase().trim();

  clearBtn.style.display = searchTerm ? 'block' : 'none';

  if (searchTerm) {
    const spaltenCbs = document.querySelectorAll('#leistungenTab .spalte');

    // Snapshot einmalig sichern – wird nie verändert
    if (!originalColumnSelection) {
      originalColumnSelection = Array.from(spaltenCbs).map(cb => ({
        value: cb.value,
        checked: cb.checked
      }));
    }

    if (!sucheTabelleBereit) {
      if (alleLeistungenFuerPBs && alleLeistungenFuerPBs.length > 0) {
        sucheTabelleBereit = true;
        _renderAlleSpalten(searchTerm);
      } else {
        ladeLeistungen({ forceCols: true }).then(() => {
          sucheTabelleBereit = true;
          setTimeout(() => performSearch(searchTerm), 30);
        });
      }
    } else {
      performSearch(searchTerm);
    }

  } else {
    // Suche gelöscht → exakt auf Snapshot zurücksetzen
    sucheTabelleBereit = false;
    searchActivatedColumns = new Set();
    manuallyChangedColumns = new Set();
    
    if (originalColumnSelection) {
      const spaltenCbs = document.querySelectorAll('#leistungenTab .spalte');
      // Alle Checkboxen auf den gespeicherten Zustand setzen
      spaltenCbs.forEach(cb => {
        const orig = originalColumnSelection.find(o => o.value === cb.value);
        if (orig) cb.checked = orig.checked;
      });
      originalColumnSelection = null;
      baueFilter();
      ladeLeistungen(); // Tabelle neu laden mit den original-Spalten
    } else {
      performSearch('');
    }
  }
}

function _renderAlleSpalten(searchTerm) {
  const leistungenTab = document.getElementById('leistungenTab');
  const alleSpalten   = Array.from(leistungenTab.querySelectorAll('.spalte')).map(c => c.value);

  const sortierteDaten = [...alleLeistungenFuerPBs].sort((a, b) => {
    if (!a.datum && !b.datum) return 0;
    if (!a.datum) return 1;
    if (!b.datum) return -1;
    return b.datum.localeCompare(a.datum);
  });
  const angezeigteDaten = sortierteDaten.map(row => {
    const filtered = {};
    alleSpalten.forEach(col => {
      if (Object.prototype.hasOwnProperty.call(row, col)) filtered[col] = row[col];
    });
    return filtered;
  });
  zeigeTabelleMitPBs(angezeigteDaten, sortierteDaten, 'leistungenAusgabe', true);
  setTimeout(() => performSearch(searchTerm), 30);
}

function performSearch(searchTerm) {
  const table = document.querySelector('#leistungenAusgabe table');
  const resultsInfo = document.querySelector('#leistungenAusgabe .results-info .results-count');
  
  if (!table) return;

  const allRows = Array.from(table.querySelectorAll('tr'));
  if (allRows.length === 0) return;

  const headerRow   = allRows[0];
  const dataRows    = allRows.slice(1).filter(r => !r.classList.contains('year-separator'));
  const headerCells = Array.from(headerRow.querySelectorAll('th'));
  let visibleCount  = 0;

  if (!searchTerm) {
    headerRow.style.display = '';
    headerCells.forEach(h => h.style.display = '');
    allRows.slice(1).forEach(row => {
      row.style.display = '';
      removeHighlights(row);
      row.querySelectorAll('td').forEach(td => td.style.display = '');
    });
    // Setze die Info-Zeile zurück auf die Gesamtzahl
    if (resultsInfo) {
      resultsInfo.textContent = `📋 ${dataRows.length} ${dataRows.length === 1 ? 'Leistung' : 'Leistungen'} gefunden`;
      resultsInfo.style.color = '';
    }
    return;
  }

  // Hilfsfunktion: Checkbox für Header-Text finden
  const spaltenCbs = document.querySelectorAll('#leistungenTab .spalte');
  function cbFuerHeader(th) {
    const t = th.textContent.trim().replace(/[▲▼]/g, '').trim().toLowerCase();
    return Array.from(spaltenCbs).find(cb => {
      const d = (SPALTEN_ANZEIGE[cb.value] || cb.value).toLowerCase();
      return d === t || cb.value.toLowerCase() === t;
    });
  }

  // Spalten-Index-Map: th-Index → cb (Aktionsspalte hat keine cb → null)
  const thCbMap = headerCells.map(th => cbFuerHeader(th));

  // Zeilen durchsuchen – welche th-Indizes haben Treffer?
  const columnHasMatch = new Array(headerCells.length).fill(false);

  dataRows.forEach(row => {
    const cells = Array.from(row.querySelectorAll('td'));
    let rowHasMatch = false;

    // td-Index entspricht th-Index (beide vollständig, da Tabelle mit allen Spalten gerendert)
    cells.forEach((td, i) => {
      if (i >= headerCells.length) return; // Aktionsspalte überspringen
      const cb = thCbMap[i];
      const th = headerCells[i];
      // Aktionsspalte komplett ignorieren
      const istAktionsSpalte = !cb || (th && th.textContent.trim().toLowerCase().includes('aktion'));
      if (istAktionsSpalte) return; // Aktionsspalte überspringen
      
      if (td.textContent.toLowerCase().includes(searchTerm)) {
        rowHasMatch = true;
        columnHasMatch[i] = true;
      }
    });

    if (rowHasMatch) {
      row.style.display = '';
      visibleCount++;
      highlightSearchTerm(row, searchTerm);
    } else {
      row.style.display = 'none';
      removeHighlights(row);
    }
  });

  // Year-separator Zeilen immer anzeigen
  allRows.slice(1).filter(r => r.classList.contains('year-separator')).forEach(r => r.style.display = '');

  // Checkboxen aktualisieren:
  // • Manuell geänderte Spalten → nicht anfassen
  // • Treffer + nicht aktiv → aktivieren, in searchActivatedColumns merken
  // • In searchActivatedColumns + kein Treffer → deaktivieren, entfernen
  // • Nicht in searchActivatedColumns → nicht anfassen (manuell oder original)
  let filterNeuBauen = false;
  headerCells.forEach((th, i) => {
    const cb = thCbMap[i];
    if (!cb) return;
    
    // Wenn die Spalte manuell geändert wurde, nicht anfassen
    if (manuallyChangedColumns.has(cb.value)) {
      return;
    }
    
    if (columnHasMatch[i]) {
      if (!cb.checked) {
        cb.checked = true;
        searchActivatedColumns.add(cb.value);
        filterNeuBauen = true;
      }
    } else {
      if (searchActivatedColumns.has(cb.value) && cb.checked) {
        cb.checked = false;
        searchActivatedColumns.delete(cb.value);
        filterNeuBauen = true;
      }
    }
  });
  if (filterNeuBauen) baueFilter();

  // Spalten ein-/ausblenden: nach aktuellem cb.checked
  // Aktionsspalte (letztes th / letztes td) immer anzeigen
  headerRow.style.display = '';
  headerCells.forEach((th, i) => {
    const cb = thCbMap[i];
    // Aktionsspalte (kein cb) ODER wenn Header "Aktionen" enthält → immer sichtbar
    const istAktionsSpalte = !cb || th.textContent.trim().toLowerCase().includes('aktion');
    th.style.display = (istAktionsSpalte || cb.checked) ? '' : 'none';
  });
  dataRows.forEach(row => {
    const cells = Array.from(row.querySelectorAll('td'));
    cells.forEach((td, i) => {
      if (i >= headerCells.length) { td.style.display = ''; return; } // Aktionsspalte
      const cb = thCbMap[i];
      const th = headerCells[i];
      // Aktionsspalte (kein cb) ODER wenn Header "Aktionen" enthält → immer sichtbar
      const istAktionsSpalte = !cb || (th && th.textContent.trim().toLowerCase().includes('aktion'));
      td.style.display = (istAktionsSpalte || cb.checked) ? '' : 'none';
    });
  });

  // Aktualisiere die Info-Zeile über der Tabelle
  if (resultsInfo) {
    if (visibleCount === 0) {
      resultsInfo.textContent = `🔍 Keine Treffer für "${searchTerm}"`;
      resultsInfo.style.color = '#dc3545';
    } else {
      resultsInfo.textContent = `🔍 ${visibleCount} von ${dataRows.length} ${visibleCount === 1 ? 'Leistung' : 'Leistungen'} gefunden`;
      resultsInfo.style.color = '';
    }
  }
}

function highlightSearchTerm(row, searchTerm) {
  removeHighlights(row);
  const cells = row.querySelectorAll('td');
  
  cells.forEach((cell, cellIndex) => {
    // Prüfe ob dies die Aktionsspalte ist (enthält Button mit "Bearbeiten")
    const hatButton = cell.querySelector('button');
    const istAktionsSpalte = hatButton && cell.textContent.toLowerCase().includes('bearbeiten');
    
    // Aktionsspalte überspringen
    if (istAktionsSpalte) return;
    
    const text = cell.textContent;
    const lowerText = text.toLowerCase();
    const index = lowerText.indexOf(searchTerm);
    
    if (index !== -1) {
      const before = text.substring(0, index);
      const match = text.substring(index, index + searchTerm.length);
      const after = text.substring(index + searchTerm.length);
      
      cell.innerHTML = `${escapeHtml(before)}<mark style="background-color: #ffd700; color: #000; padding: 2px 4px; border-radius: 3px; font-weight: 600;">${escapeHtml(match)}</mark>${escapeHtml(after)}`;
    }
  });
}

function removeHighlights(row) {
  const marks = row.querySelectorAll('mark');
  marks.forEach(mark => {
    const parent = mark.parentNode;
    parent.replaceChild(document.createTextNode(mark.textContent), mark);
    parent.normalize();
  });
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function clearTableSearch() {
  const searchInput = document.getElementById('tableSearchInput');
  searchInput.value = '';
  filterTable();
  searchInput.focus();
}

// Live-Suche beim Tippen (Debounce) + Enter
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('tableSearchInput');
  if (searchInput) {
    let _sd = null;
    searchInput.addEventListener('input', function() {
      clearTimeout(_sd);
      _sd = setTimeout(() => filterTable(), 300);
    });
    searchInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); clearTimeout(_sd); filterTable(); }
    });
  }
  
  // Event-Listener für manuelle Checkbox-Änderungen während der Suche
  const spaltenCheckboxen = document.querySelectorAll('#leistungenTab .spalte');
  spaltenCheckboxen.forEach(cb => {
    cb.addEventListener('change', function() {
      // Nur tracken wenn eine Suche aktiv ist
      const searchInput = document.getElementById('tableSearchInput');
      if (searchInput && searchInput.value.trim()) {
        // Merke diese Spalte als manuell geändert
        manuallyChangedColumns.add(cb.value);
        
        // Wenn die Spalte durch die Suche aktiviert wurde, entferne sie aus dem Set
        if (searchActivatedColumns.has(cb.value)) {
          searchActivatedColumns.delete(cb.value);
        }
        
        // Aktualisiere die Ansicht
        baueFilter();
        performSearch(searchInput.value.toLowerCase().trim());
      }
    });
  });
});



/* ================= PDF REPORT GENERATOR ================= */

function vergleicheLeistungen(leistung1, leistung2, disziplin) {
  // Zeit-Disziplinen: niedrigere Zeit ist besser
  const zeitDisziplinen = ['100m', '200m', '400m', '800m', '1500m', '3000m', '5000m', '10000m', 
                          '110m Hü.', '100m Hü.', '400m Hü.', '3000m Hi.', '60m', '60m Hü.'];
  
  if (zeitDisziplinen.some(d => disziplin.includes(d))) {
    return leistung1 < leistung2;
  }
  
  // Feld-Disziplinen: höhere Leistung ist besser
  return leistung1 > leistung2;
}

</script>

