<div id="templateFormModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:10003; justify-content:center; align-items:center; padding:20px;" onclick="if(event.target===this) closeTemplateForm()">
  <div style="background:#f2f6fa; padding:22px; border-radius:12px; max-width:480px; width:100%; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
      <h2 id="tplFormTitle" style="color:navy; margin:0; font-size:1.15em;">Neue Vorlage</h2>
      <button onclick="closeTemplateForm()" aria-label="Schließen" class="modal-close-btn">×</button>
    </div>
    <div style="margin-bottom:12px;">
      <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Name *</label>
      <input type="text" id="tpName" placeholder="z.B. Intervalle 4×400m" style="width:100%; padding:9px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box;">
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px;">
      <div>
        <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Dauer (min)</label>
        <div style="display:flex; align-items:center; gap:6px;">
          <input type="number" id="tpDuration" placeholder="60" min="0" step="10" style="flex:1; min-width:0; padding:8px 6px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box; text-align:center;">
          <div style="display:flex; border:2px solid #e0e0e0; border-radius:8px; overflow:hidden; flex-shrink:0;">
            <button type="button" onclick="tpDurationStep(-10)" style="width:30px; height:34px; border:none; border-right:1px solid #e0e0e0; background:white; color:#1e3a8a; font-size:1.15em; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:0;" title="-10 min">−</button>
            <button type="button" onclick="tpDurationStep(10)"  style="width:30px; height:34px; border:none; background:white; color:#1e3a8a; font-size:1.15em; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:0;" title="+10 min">+</button>
          </div>
        </div>
      </div>
      <div>
        <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Intensität</label>
        <select id="tpIntensity" style="width:100%; padding:9px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box;">
          <option value="">-</option>
          <option value="low">Locker</option>
          <option value="medium">Mittel</option>
          <option value="high">Hoch</option>
        </select>
      </div>
    </div>
    <div style="margin-bottom:14px;">
      <label style="display:block; margin-bottom:6px; font-weight:600; font-size:0.85em; color:#333;">Farbe</label>
      <div id="tpColorPicker" class="tpl-color-picker"></div>
    </div>
    <div style="margin-bottom:14px;">
      <label style="display:block; margin-bottom:4px; font-weight:600; font-size:0.85em; color:#333;">Beschreibung</label>
      <textarea id="tpDescription" placeholder="Optionale Details (Strecken, Pausen, Schuhe…)" rows="3" style="width:100%; padding:9px; border:2px solid #e0e0e0; border-radius:8px; font-size:0.9em; box-sizing:border-box; resize:vertical; font-family:inherit;"></textarea>
    </div>
    <p style="font-size:0.78em; color:#666; margin:0 0 12px;">* Pflichtfeld</p>
    <div style="display:flex; gap:10px; justify-content:space-between; align-items:center;">
      <button id="tpDeleteBtn" onclick="deleteTemplateFromForm()" style="display:none; padding:9px 14px; border:none; border-radius:8px; cursor:pointer; font-weight:600; background:#dc2626; color:white;">Löschen</button>
      <div style="display:flex; gap:10px; margin-left:auto;">
        <button onclick="closeTemplateForm()" style="padding:9px 18px; border:none; border-radius:8px; cursor:pointer; font-weight:600; background:#6c757d; color:white;">Abbrechen</button>
        <button onclick="saveTemplateFromForm()" style="padding:9px 18px; border:none; border-radius:8px; cursor:pointer; font-weight:600; background:linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%); color:white;">Speichern</button>
      </div>
    </div>
  </div>
</div>

