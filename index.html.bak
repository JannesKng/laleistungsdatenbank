        grid-template-columns: 1fr 1fr;
        gap: 6px;
      }
      
      .detail-info-item {
        padding: 8px 10px;
      }
      
      .detail-info-label {
        font-size: 0.6em;
      }
      
      .detail-info-value {
        font-size: 0.85em;
      }
      
      .detail-visualizations {
        grid-template-columns: 1fr;
