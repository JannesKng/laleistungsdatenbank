}

/* ================= BESTLEISTUNGEN FILTER TOOLBAR ================= */

function toggleBlFilterDropdown() {
  toggleLtDropdown('blFilterDropdown', 'blFilterBtn');
}

function onBlZeitraumChange() {
  const val = document.getElementById('bestleistungenFilterZeitraum').value;
  const range = document.getElementById('bestleistungenCustomDateRange');
  if (range) range.style.display = val === 'custom' ? 'block' : 'none';
  updateBlFilterUI();
}

function updateBlFilterUI() {
  const fields = [
    { id: 'bestleistungenFilterDisziplin', label: 'Disziplin',     type: 'select' },
    { id: 'bestleistungenFilterZeitraum',  label: 'Zeitraum',      type: 'select-jahr' },
    { id: 'bestleistungenFilterVon',       label: 'Von',           type: 'date' },
    { id: 'bestleistungenFilterBis',       label: 'Bis',           type: 'date' },
    { id: 'bestleistungenFilterOrt',       label: 'Ort',           type: 'text' },
    { id: 'bestleistungenFilterWK',        label: 'Wettkampf',     type: 'text' },
    { id: 'bestleistungenFilterAK',        label: 'Altersklasse',  type: 'text' },
    { id: 'bestleistungenFilterTyp',       label: 'Saison',        type: 'select' },
    { id: 'bestleistungenFilterMS',        label: 'Meisterschaft', type: 'select' },
  ];

  const chips = [];
  fields.forEach(({ id, label, type }) => {
    const el = document.getElementById(id);
    if (!el || !el.value) return;
    if (id === 'bestleistungenFilterVon' || id === 'bestleistungenFilterBis') {
      const zt = document.getElementById('bestleistungenFilterZeitraum');
      if (!zt || zt.value !== 'custom') return;
    }
    const displayVal = type === 'select' || type === 'select-jahr'
      ? (el.options[el.selectedIndex]?.text || el.value)
      : el.value;
    chips.push({ label, value: displayVal, id });
  });

  // Badge
  const badge = document.getElementById('blFilterBadge');
  if (badge) {
    badge.textContent = chips.length;
    badge.style.display = chips.length > 0 ? 'inline-flex' : 'none';
  }
  const btn = document.getElementById('blFilterBtn');
  if (btn) btn.classList.toggle('lt-active', chips.length > 0);

  // Chips container
  const container = document.getElementById('blChipsContainer');
  if (!container) return;
  container.innerHTML = '';
  container.style.display = chips.length > 0 ? 'flex' : 'none';
  chips.forEach(({ label, value, id }) => {
    const chip = document.createElement('span');
    chip.className = 'lt-chip';
    const safeId = id.replace(/'/g, "\'");
    chip.innerHTML =
      `<span class="lt-chip-key">${label}:</span> ${value}` +
      `<button class="lt-chip-remove" title="Filter entfernen" onclick="removeBlChip('${safeId}')">×</button>`;
    container.appendChild(chip);
  });
}

function removeBlChip(fieldId) {
  const el = document.getElementById(fieldId);
  if (!el) return;
  el.value = '';
  if (fieldId === 'bestleistungenFilterZeitraum') {
    const range = document.getElementById('bestleistungenCustomDateRange');
    if (range) range.style.display = 'none';
    document.getElementById('bestleistungenFilterVon').value = '';
    document.getElementById('bestleistungenFilterBis').value = '';
  }
  updateBlFilterUI();
}

/* ================= WETTKAMPFORTE KARTE (Leaflet) ================= */

// Globale Leaflet-Karte für Wettkampforte
let _wettkampfLeafletMap = null;
let _wettkampfMarkerLayer = null;
let _wettkampfInitialBounds = null;
let _wettkampfLeistungenRef = [];

function resetMapZoom() {
  if (_wettkampfLeafletMap && _wettkampfInitialBounds) {
    _wettkampfLeafletMap.fitBounds(_wettkampfInitialBounds, { padding: [40, 40], maxZoom: 13 });
  }
}

function toggleMapFullscreen() {
  const container = document.getElementById('mapContainer');
  const icon = document.getElementById('mapFullscreenIcon');
  const isFullscreen = container.classList.toggle('fullscreen');

  // Expand/collapse icon swap
  if (isFullscreen) {
    icon.innerHTML = '<polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/>';
    document.body.style.overflow = 'hidden';
  } else {
    icon.innerHTML = '<polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>';
    document.body.style.overflow = '';
  }

  // Re-invalidate map size after transition
  setTimeout(() => {
    if (_wettkampfLeafletMap) _wettkampfLeafletMap.invalidateSize();
  }, 50);
}

// ESC closes fullscreen
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    const container = document.getElementById('mapContainer');
    if (container && container.classList.contains('fullscreen')) {
      toggleMapFullscreen();
    }
  }
});

async function updateWettkampforteMap(leistungen) {
  console.log('Aktualisiere Wettkampforte-Karte mit', leistungen.length, 'Leistungen');
  _wettkampfLeistungenRef = leistungen;
  window._geocodeCache = {}; // Cache leeren damit verbessertes Geocoding greift

  // Karte initialisieren (einmalig)
  if (!_wettkampfLeafletMap) {
    const mapDiv = document.getElementById('wettkampfLeafletMap');
    if (!mapDiv) return;
    _wettkampfLeafletMap = L.map('wettkampfLeafletMap', {
      center: [51.163375, 10.447683],
      zoom: 6,
      zoomControl: true
    });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '\u00a9 <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19
    }).addTo(_wettkampfLeafletMap);
    _wettkampfMarkerLayer = L.layerGroup().addTo(_wettkampfLeafletMap);
  } else {
    _wettkampfMarkerLayer.clearLayers();
  }

  // Leistungen pro Ort zählen
  const ortCount = {};
  leistungen.forEach(l => {
    if (l.ort && l.ort.trim()) {
      const key = l.ort.trim();
      ortCount[key] = (ortCount[key] || 0) + 1;
    }
  });

  if (Object.keys(ortCount).length === 0) return;

  // Geocoding mit Cache + parallele Anfragen
  const cache = window._geocodeCache || (window._geocodeCache = {});
  const orte = Object.entries(ortCount);

  // Hilfsfunktion: einen Ort geocodieren via Nominatim (CORS-Proxy) mit Europe-Bias
  async function geocodeOrt(ort) {
    const cacheKey = ort.toLowerCase().trim();
    if (cache[cacheKey] !== undefined) return { ort, coords: cache[cacheKey] };

    // Nominatim über corsproxy.io – unterstützt countrycodes + viewbox für Europa
    // Zuerst ohne countrycodes versuchen, aber mit Europa-viewbox und featuretype=city
    const nominatimUrl = 'https://nominatim.openstreetmap.org/search?format=json&limit=5&addressdetails=1&featuretype=city&viewbox=-25,34,45,72&bounded=0&q=' + encodeURIComponent(ort);
    const proxyUrl = 'https://corsproxy.io/?' + encodeURIComponent(nominatimUrl);

    try {
      const resp = await fetch(proxyUrl);
      const data = await resp.json();
      let coords = null;

      if (data && data.length > 0) {
        // Bevorzuge place=city/town/village über andere Typen
        const stadtTypen = ['city', 'town', 'village', 'municipality'];
        const stadtResult = data.find(r => stadtTypen.includes(r.addresstype || r.type));
        const best = stadtResult || data[0];
        coords = { lat: parseFloat(best.lat), lon: parseFloat(best.lon) };
      }

      cache[cacheKey] = coords;
      return { ort, coords };
    } catch(e) {
      console.warn('Geocoding fehlgeschlagen für:', ort, e);
      cache[cacheKey] = null;
      return { ort, coords: null };
    }
  }

  // Alle Orte parallel anfragen (ohne Wartezeit)
  const geocodeResults = await Promise.all(orte.map(([ort]) => geocodeOrt(ort)));

  // Marker sofort nach Ergebnis setzen
  const bounds = [];
  for (const { ort, coords } of geocodeResults) {
    if (!coords) continue;
    const count = ortCount[ort];

    // Größe und Farbe nach Anzahl (kompakter, weniger transparent)
    let radius, fillColor, strokeColor;
    if      (count <= 2)  { radius =  5; fillColor = '#b3d9ff'; strokeColor = '#66a3d2'; }
    else if (count <= 5)  { radius =  7; fillColor = '#80bfff'; strokeColor = '#4d94d9'; }
    else if (count <= 10) { radius =  9; fillColor = '#4da6ff'; strokeColor = '#3385d6'; }
    else if (count <= 20) { radius = 11; fillColor = '#1a8cff'; strokeColor = '#1a75d2'; }
    else                  { radius = 13; fillColor = '#0066cc'; strokeColor = '#004d99'; }

    const marker = L.circleMarker([coords.lat, coords.lon], {
      radius, fillColor, color: strokeColor,
      weight: 1.5, opacity: 1, fillOpacity: 0.95
    });

    marker.bindTooltip(
      '<strong>' + ort + '</strong><br>' + count + ' Leistung' + (count > 1 ? 'en' : ''),
      { direction: 'top', offset: [0, -5] }
    );

    const ortKey = normalizeOrtName(ort);
    marker.on('click', () => showOrtLeistungen(ortKey, _wettkampfLeistungenRef));

    _wettkampfMarkerLayer.addLayer(marker);
    bounds.push([coords.lat, coords.lon]);
  }

  // Karte auf alle Marker zoomen + initialBounds speichern
  if (bounds.length > 0) {
    try {
      const lBounds = L.latLngBounds(bounds);
      _wettkampfInitialBounds = lBounds; // für Reset-Button
      _wettkampfLeafletMap.fitBounds(lBounds, { padding: [40, 40], maxZoom: 13 });
    } catch(e) { /* ignore */ }
  }
}


// Globale Variablen für die aktuell angezeigte Orts-Tabelle
let currentOrtLeistungen = [];
let currentOrtName = '';
let ortTableSortColumn = 'datum';
let ortTableSortAsc = false;

// Funktion zum Anzeigen von Leistungen eines Ortes als POPUP
function showOrtLeistungen(ort, leistungen) {
  currentOrtLeistungen = leistungen.filter(l => normalizeOrtName(l.ort) === ort);
  currentOrtName = ort;

  if (currentOrtLeistungen.length === 0) return;

  ortTableSortColumn = 'datum';
  ortTableSortAsc = false;
  sortOrtTable();

  renderOrtPopup();
}

// Sortiere Orts-Tabelle
function sortOrtTable() {
  currentOrtLeistungen.sort((a, b) => {
    let valA = a[ortTableSortColumn];
    let valB = b[ortTableSortColumn];
    if (valA === null || valA === undefined) return 1;
    if (valB === null || valB === undefined) return -1;
    if (ortTableSortColumn === 'datum') { valA = new Date(valA); valB = new Date(valB); }
    if (ortTableSortColumn === 'leistung') { valA = Number(valA); valB = Number(valB); }
    if (typeof valA === 'string') { valA = valA.toLowerCase(); valB = valB.toLowerCase(); }
    if (valA < valB) return ortTableSortAsc ? -1 : 1;
    if (valA > valB) return ortTableSortAsc ? 1 : -1;
    return 0;
  });
}

function setOrtTableSort(spalte) {
  if (ortTableSortColumn === spalte) { ortTableSortAsc = !ortTableSortAsc; }
  else { ortTableSortColumn = spalte; ortTableSortAsc = true; }
  sortOrtTable();
  renderOrtPopup();
}

// Top 3 Disziplinen ermitteln (beste Leistung je Disziplin)
function getTop3Disziplinen(leistungen) {
  const diszMap = {};
  leistungen.forEach(l => {
    if (!l.disziplin || l.leistung == null) return;
    const key = l.disziplin;
    if (!diszMap[key]) diszMap[key] = [];
    diszMap[key].push(l);
  });

  // Beste Leistung je Disziplin
  const bests = Object.entries(diszMap).map(([disziplin, ls]) => {
    // Sortiere: kleinere Leistung besser (Zeit) oder größere (Weite/Höhe)?
    // Verwende count als Kriterium für Dominanz + beste Leistung numerisch
    const sorted = ls.slice().sort((a, b) => {
      const av = parseFloat(a.leistung);
      const bv = parseFloat(b.leistung);
      // Laufende Disziplinen: kleinerer Wert besser
      const isTime = /^\d{1,2}[.,]\d+$/.test(String(a.leistung)) || ls.some(x => String(x.leistung).includes(':'));
      return isTime ? av - bv : bv - av;
    });
    return { disziplin, beste: sorted[0], anzahl: ls.length };
  });

  // Sortiere Top-Disziplinen nach Anzahl Leistungen (Hauptdisziplinen zuerst)
  bests.sort((a, b) => b.anzahl - a.anzahl);
  return bests.slice(0, 3);
}

// Rendere Orts-Popup
function renderOrtPopup() {
  const overlay = document.getElementById('ortLeistungenPopupOverlay');
  const title = document.getElementById('ortPopupTitle');
  const tbody = document.getElementById('ortPopupTbody');
  const countEl = document.getElementById('ortPopupCount');

  if (!overlay) return;

  // Titel
  title.textContent = '📍 ' + currentOrtName;

  // Anzahl
  if (countEl) countEl.textContent = currentOrtLeistungen.length + ' ' + (currentOrtLeistungen.length === 1 ? 'Leistung' : 'Leistungen');

  // Tabelle
  if (tbody) {
    tbody.innerHTML = '';
    currentOrtLeistungen.forEach(leistung => {
      const datumFormatiert = leistung.datum ? formatiereDatum(leistung.datum) : '-';
      const leistungFormatiert = (leistung.leistung != null) ? formatiereLeistung(leistung.leistung, leistung.disziplin) : '-';
      const tr = document.createElement('tr');
      tr.dataset.leistungId = leistung.id || '';
      tr.style.cursor = 'pointer';
      tr.innerHTML = `
        <td>${datumFormatiert}</td>
        <td>${leistung.disziplin || '-'}</td>
        <td>${leistungFormatiert}</td>
        <td>${leistung.wk_bz || '-'}</td>
      `;
      tr.addEventListener('click', () => {
        closeOrtLeistungenPopup();
        setTimeout(() => openDetailPopup(leistung), 150);
      });
      tbody.appendChild(tr);
    });
  }

  // Sortier-Header aktualisieren
  document.querySelectorAll('.ort-popup-sort-th').forEach(th => {
    const col = th.dataset.col;
    const pfeil = ortTableSortColumn === col ? (ortTableSortAsc ? ' ▲' : ' ▼') : '';
    th.querySelector('.sort-arrow').textContent = pfeil;
  });

  overlay.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeOrtLeistungenPopup() {
  const overlay = document.getElementById('ortLeistungenPopupOverlay');
  if (overlay) overlay.style.display = 'none';
  document.body.style.overflow = '';
}

// Alte Funktionen als Fallback (werden nicht mehr für Rendering genutzt)
function renderOrtTable() { renderOrtPopup(); }

function hideOrtLeistungen() {
  closeOrtLeistungenPopup();
  const ortTable = document.getElementById('ortLeistungenTable');
  const bottomSection = document.getElementById('bottomSection');
  const mobileContainer = document.getElementById('ortTableMobileContainer');
  if (ortTable) ortTable.innerHTML = '';
  if (mobileContainer) mobileContainer.style.display = 'none';
  if (bottomSection) bottomSection.style.gridTemplateColumns = '1fr';
}

// ---- CSS für Ort-Popup (inline hier, damit Dark-Mode korrekt greift) ----
(function injectOrtPopupStyles() {
  if (document.getElementById('ortPopupStyles')) return;
  const style = document.createElement('style');
  style.id = 'ortPopupStyles';
  style.textContent = `
  
    /* Detail Popup Modal Styles */
    .detail-popup {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.6);
      z-index: 10001;
      justify-content: center;
      align-items: center;
      padding: 20px;
      overflow-y: auto;
    }

    .detail-popup-content {
      background: #f2f6fa;
      border-radius: var(--border-radius);
      max-width: 1200px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      position: relative;
    }

    .detail-popup-header {
      background: linear-gradient(135deg, var(--header-bg-start) 0%, var(--header-bg-end) 100%);
      color: white;
      padding: 25px 30px;
      border-radius: var(--border-radius) var(--border-radius) 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .detail-popup-header h2 {
      margin: 0;
      color: navy;
      font-size: 1.8em;
    }

    .detail-popup-close {
      background: white;
      border: 2px solid navy;
      color: navy;
      font-size: 1.5em;
      cursor: pointer;
      padding: 0;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      transition: all 0.2s;
      flex-shrink: 0;
      line-height: 1;
    }

    .detail-popup-close:hover {
      background: #e8eef8;
    }




















    .detail-popup-body {
      padding: 30px;
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .detail-info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .detail-info-item {
      padding: 15px;
      background: var(--input-bg);
      border-radius: 8px;
      border-left: 4px solid var(--btn-primary-bg);
      transition: all 0.3s;
    }

    .detail-info-item:hover {
      box-shadow: 0 2px 8px var(--shadow-color);
      transform: translateX(2px);
    }

    .detail-info-label {
      font-size: 0.85em;
      color: var(--text-secondary);
      margin-bottom: 5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .detail-info-value {
      font-size: 1.3em;
      color: var(--text-primary);
      font-weight: 700;
    }

    .detail-section {
      margin-bottom: 30px;
    }

    .detail-section h3 {
      color: var(--text-primary);
      margin-bottom: 15px;
      font-size: 1.3em;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .detail-section h3::before {
      content: '';
      width: 4px;
      height: 24px;
      background: linear-gradient(135deg, var(--header-bg-start) 0%, var(--header-bg-end) 100%);
      border-radius: 2px;
    }

    .detail-map-container {
      height: 100%;
      min-height: 340px;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 15px var(--shadow-color);
    }

    .detail-chart-container {
      position: relative;
      height: 100%;
      min-height: 340px;
      padding: 20px;
      background: var(--input-bg);
      border-radius: 10px;
    }

    /* Dark Mode Anpassungen für Detail Popup */
/* ========== RESPONSIVE DESIGN ========== */
    
    /* Große Bildschirme (1920px+) */
    @media (min-width: 1920px) {
      .detail-popup-content {
        max-width: 1800px;
        height: 92vh;
      }
      
      .detail-visualizations {
        grid-template-columns: 62% 38%;
        gap: 20px;
      }

